digraph ideal_system {
    rankdir=TB;
    bgcolor="white";
    pad=0.4;
    nodesep=0.5;
    ranksep=0.5;
    dpi=200;
    
    node [
        shape=box, style="rounded,filled", fontname="DejaVu Sans",
        fontsize=10, width=2.2, height=0.45, penwidth=1.3
    ];
    edge [
        fontname="DejaVu Sans", fontsize=8, color="#666666",
        arrowsize=0.7, penwidth=1.1
    ];

    // Title
    title [label="Ideal System: Full Service-to-Invoice Flow", shape=none, fillcolor=white,
           fontsize=15, fontname="DejaVu Sans Bold", fontcolor="#1B3A5C"];

    // === PHASE 1: Request & Execution (left column) ===
    subgraph cluster_phase1 {
        label="Phase 1: Request & Execution"; labeljust=l;
        fontname="DejaVu Sans Bold"; fontsize=10; fontcolor="#1B3A5C";
        style="rounded,dashed"; color="#CCCCCC"; bgcolor="#FAFAFA"; margin=12;

        p1_1 [label="1. Client contacts RCH", fillcolor="#F0F0F0", color="#AAAAAA", fontcolor="#555555"];
        p1_2 [label="2. AM logs request in CRM\n(client, company, service, names)", fillcolor="#E8E8E8", color="#999999", fontcolor="#333333"];
        p1_new [label="New client? Retainer or Per-Job?\nUpload agreement if needed", fillcolor="#FFF3E0", color="#E65100", fontcolor="#BF360C", fontsize=9];
        p1_3 [label="3. AM forwards to Operations", fillcolor="#E8E8E8", color="#999999", fontcolor="#333333"];
        p1_4 [label="4. OPs executes service, notes\ncard used, gathers receipts", fillcolor="#E8E8E8", color="#999999", fontcolor="#333333"];
        p1_5 [label="5. Receipts + info back to AM", fillcolor="#E8E8E8", color="#999999", fontcolor="#333333"];

        p1_1 -> p1_2; p1_2 -> p1_new [style=dashed, label=" if new"]; p1_new -> p1_3 [style=dashed]; p1_2 -> p1_3; p1_3 -> p1_4; p1_4 -> p1_5;
    }

    // === PHASE 2: Logging & Verification (middle column) ===
    subgraph cluster_phase2 {
        label="Phase 2: Logging & Verification"; labeljust=l;
        fontname="DejaVu Sans Bold"; fontsize=10; fontcolor="#1B3A5C";
        style="rounded,dashed"; color="#CCCCCC"; bgcolor="#FAFAFA"; margin=12;

        p2_1 [label="6. AM logs completion in CRM:\nreceipt, govt fee, card, names,\ndates, cost center, prof fees", fillcolor="#E8E8E8", color="#999999", fontcolor="#333333", fontsize=9];
        p2_2 [label="7. ELENA (AM Team Leader)\nreviews and approves", fillcolor="#D4E6F9", color="#1565C0", fontcolor="#0D47A1"];
        p2_3 [label="8. GABI verifies payment\nvia SMS bank records", fillcolor="#FCE4EC", color="#A3195B", fontcolor="#A3195B"];
        p2_4 [label="✓ Service VERIFIED\nand ready for invoicing", fillcolor="#E8F5E9", color="#2E7D32", fontcolor="#1B5E20", fontsize=10];
        p2_auto [label="System auto-updates:\nspending, limits, dashboards", fillcolor="#E8F5E9", color="#2E7D32", fontcolor="#1B5E20", fontsize=9];

        p2_1 -> p2_2; p2_2 -> p2_3; p2_3 -> p2_4; p2_4 -> p2_auto [label=" automatic"];
    }

    // === PHASE 3: Invoicing (right column) ===
    subgraph cluster_phase3 {
        label="Phase 3: Invoicing (Thursday)"; labeljust=l;
        fontname="DejaVu Sans Bold"; fontsize=10; fontcolor="#1B3A5C";
        style="rounded,dashed"; color="#CCCCCC"; bgcolor="#FAFAFA"; margin=12;

        p3_trigger [label="Invoice trigger: Thursday\n/ client limit hit / 20-day rule", fillcolor="#FFF3E0", color="#E65100", fontcolor="#BF360C", fontsize=9];
        p3_1 [label="9. Finance picks client +\nservices (sorted by govt fees)", fillcolor="#E3EDF7", color="#1B3A5C", fontcolor="#1B3A5C"];
        p3_2 [label="10. System auto-generates\nDRAFT invoice (all fields filled)", fillcolor="#1B3A5C", color="#1B3A5C", fontcolor="white"];
        p3_3 [label="11. Finance reviews\nand approves", fillcolor="#E3EDF7", color="#1B3A5C", fontcolor="#1B3A5C"];
        p3_4 [label="12. Invoice sent to client\n+ auto-sync to accounting", fillcolor="#E8F5E9", color="#2E7D32", fontcolor="#1B5E20"];

        p3_trigger -> p3_1; p3_1 -> p3_2 [label=" 2 steps"]; p3_2 -> p3_3; p3_3 -> p3_4;
    }

    // Cross-phase connections
    p1_5 -> p2_1;
    p2_auto -> p3_trigger;

    // Force columns side by side
    {rank=same; p1_1; p2_1; p3_trigger}

    // Legend
    subgraph cluster_legend {
        label=""; style="rounded"; color="#CCCCCC"; bgcolor="#FAFAFA"; margin=8;
        leg [label="AM/OPs = gray  |  Elena = blue  |  Gabi = pink  |  Finance = navy  |  System = green  |  Decision = orange",
             shape=none, fontname="DejaVu Sans", fontsize=9, fontcolor="#666666"];
    }
}
